# ==========================================================================
#  KÉK-HÍD Egyesület — Környezeti változók MINTA
#  Másold le ".env" néven, és töltsd ki az értékeket. A .env-et SOHA ne
#  tedd verziókezelőbe (a .gitignore már kizárja).
# ==========================================================================

# Hosszú, véletlenszerű titok a munkamenetekhez/tokenekhez.
# Generálás: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=valami_nagyon_hosszu_veletlen_titok_ide

# Adatbázis kapcsolat.
#  - Helyi fejlesztés (SQLite, alapértelmezett): file:./kek-hid.db
#  - Éles (Neon/Supabase PostgreSQL):  postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URI=file:./kek-hid.db

# Az oldal nyilvános URL-je (élesben a saját domain, pl. https://kekhid.hu)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- E-mail küldés (űrlap-értesítések) — opcionális helyi fejlesztésben ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@kekhid.hu
EMAIL_TO=info@kekhid.hu

# --- Médiatárolás éles környezetben (opcionális; helyben a lemezt használja) ---
# Vercel Blob:
BLOB_READ_WRITE_TOKEN=

# --- Spam-védelem (Cloudflare Turnstile) — opcionális ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
